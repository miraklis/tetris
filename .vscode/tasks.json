{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "clang --std=c++17 src/*.cpp -g -D DEBUG -U DRAWFULL -o Debug/tetris -lstdc++ -lSDL3",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "clang --std=c++17 -O3 src/*.cpp -U DEBUG -o Release/tetris -lstdc++ -lSDL3",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }        
    ]
}
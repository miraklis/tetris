{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "clang -std=c11 src/*.c -Wall -pedantic -g -D DEBUG -o Debug/tetris -lc -lSDL3 -lm -lOpenGL",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "clang -std=c11 -O3 src/*.c -o Release/tetris -lc -lSDL3 -lm -lOpenGL",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build ASAN",
            "type": "shell",
            "command": "clang -std=c11 src/*.c -g -fsanitize=address -fsanitize=undefined -fno-omit-frame-pointer -o Debug/tetris_asan -lc -lSDL3 -lm -lOpenGL",
            "problemMatcher": []
        }        
    ]
}